<!DOCTYPE html>
<html>
<head>
  <title>Email Search Results</title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f0f2f5;
      padding: 20px;
    }
    .container {
      max-width: 1000px;
      margin: auto;
      background: white;
      border-radius: 10px;
      padding: 20px;
      box-shadow: 0px 0px 20px rgba(0,0,0,0.1);
    }
    h2 { text-align: center; margin-bottom: 20px; }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      padding: 10px;
      border: 1px solid #ddd;
      text-align: left;
    }
    th {
      background: #667eea;
      color: white;
    }
    pre {
      white-space: pre-wrap;
      font-family: inherit;
    }
    .btn {
      text-align: center;
      margin-top: 15px;
    }
    .btn a {
      background: #667eea;
      color: white;
      padding: 10px 15px;
      border-radius: 5px;
      text-decoration: none;
    }
    .btn a:hover {
      background: #5a67d8;
    }
  </style>
</head>
<body>

<div class="container">
  <h2>📧 Results for "<%= keyword %>"</h2>
  <table>
    <thead>
      <tr>
        <th>From</th>
        <th>Subject</th>
        <th>Snippet</th>
        <th>Date</th>
        <th>Full Body</th>
      </tr>
    </thead>
    <tbody>
      <% results.forEach(mail => { %>
        <tr>
          <td><%= mail.from %></td>
          <td><%= mail.subject %></td>
          <td><%= mail.snippet %></td>
          <td><%= mail.date %></td>
          <td><pre><%= mail.body %></pre></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="btn">
    <a href="/">🔍 Search Again</a>
  </div>
</div>

</body>
</html>